# .env.example
# 실제 키는 .env에만 넣고, .env는 Git 추적에서 제외하세요.

# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# 사용할 LLM 모델
CXR_AGENT_LLM_MODEL=gpt-4o-mini

# OpenAI API 기본 주소
OPENAI_BASE_URL=https://api.openai.com/v1

# Agentic Workbench 고속화 옵션
# true이면 비교/품질/Grad-CAM/ROI/질환별 확률 질문은 이미 계산된 tool output으로 즉시 답하고,
# 자유형 종합 질문만 LLM을 호출합니다.
CXR_AGENT_TOOL_FIRST_FASTPATH=true
CXR_AGENT_LLM_MAX_TOKENS=420
CXR_AGENT_LLM_TIMEOUT=20
CXR_AGENT_LLM_TEMPERATURE=0.1

# Result Analysis 고속 LLM 옵션
CXR_ANALYSIS_LLM_MAX_TOKENS=420
CXR_ANALYSIS_LLM_TIMEOUT=18
CXR_ANALYSIS_LLM_TEMPERATURE=0.15
